# KittenTTS API service
HOST=0.0.0.0
PORT=8080

# Hugging Face model used by the API container
KITTEN_MODEL=KittenML/kitten-tts-nano-0.8-int8

# Comma-separated API keys. Format: key:label
API_KEYS=dev-secret-key:development,prod-client-key:client-a

# Pay-per-request billing (USD). Each /v1/generate call records this cost.
PRICE_PER_REQUEST=0.01

# Optional monthly quota per API key (0 = unlimited)
MONTHLY_QUOTA=0

# SQLite usage database path inside the container
USAGE_DB_PATH=/data/usage.db

# CORS origins for direct browser access (WordPress proxies via PHP by default)
CORS_ORIGINS=*
