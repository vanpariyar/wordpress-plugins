{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "post-to-speech/post-audio",
	"version": "1.4.0",
	"title": "Post to Speech",
	"category": "media",
	"icon": "controls-volumeon",
	"description": "Convert post content or custom text to speech and embed an audio player.",
	"keywords": [ "audio", "text-to-speech", "gutenberg", "speech", "blog" ],
	"textdomain": "post-to-speech",
	"attributes": {
		"textSource": {
			"type": "string",
			"default": "post"
		},
		"text": {
			"type": "string",
			"default": ""
		},
		"audioUrl": {
			"type": "string",
			"default": ""
		},
		"attachmentId": {
			"type": "number"
		},
		"voice": {
			"type": "string",
			"default": "Bella"
		},
		"speed": {
			"type": "number",
			"default": 1
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
