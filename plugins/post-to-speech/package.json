{
	"name": "post-to-speech",
	"version": "1.4.0",
	"description": "Convert WordPress posts to speech and embed an audio player with a Gutenberg block.",
	"author": "Ronak Vanpariya",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"copy:vendor": "mkdir -p assets/vendor/espeak-ng && cp node_modules/espeak-ng/dist/espeak-ng.js node_modules/espeak-ng/dist/espeak-ng.wasm assets/vendor/espeak-ng/",
		"build": "npm run copy:vendor && wp-scripts build",
		"postinstall": "npm run copy:vendor",
		"start": "wp-scripts start",
		"test": "wp-scripts test-unit-js",
		"lint:js": "wp-scripts lint-js",
		"format": "wp-scripts format"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.0.0",
		"espeak-ng": "^1.0.2",
		"fflate": "^0.8.2",
		"npyjs": "^0.6.0"
	}
}
